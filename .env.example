SENTINEL_LLM_PROVIDER=huggingface
SENTINEL_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
SENTINEL_OLLAMA_FALLBACK_MODEL=qwen2.5-coder:7b

# Optional Hugging Face hosted/local provider settings.
HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1

# Solodit RAG. Regenerate exposed keys before placing them here.
SOLODIT_API_URL=https://solodit.cyfrin.io/api/v1/solodit
SOLODIT_API_KEY=
SENTINEL_RAG_DIR=data/rag
# Default stays MiniLM because it is fast and local-friendly. MPNet/BGE can be
# tested with `sentinel rag eval-embeddings` and require rebuilding indexes.
SENTINEL_RAG_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Optional higher-quality local candidates:
# SENTINEL_RAG_EMBED_MODEL=sentence-transformers/all-mpnet-base-v2
# SENTINEL_RAG_EMBED_MODEL=BAAI/bge-base-en-v1.5
SENTINEL_RAG_STALE_AFTER_HOURS=24
SENTINEL_RAG_DEFAULT_PAGE_SIZE=100
SENTINEL_RAG_FILTER_LANGUAGES=Solidity
SENTINEL_RAG_FILTER_IMPACTS=HIGH,MEDIUM
SENTINEL_RAG_QUALITY_SCORE=2
SENTINEL_RAG_AUTO_REBUILD=false

# Optional LangSmith tracing.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=solidity-sentinel-agent
